{
  "name": "quickcard-backend",
  "version": "1.0.0",
  "description": "QuickCard – Your Business Card Mitra Backend",
  "author": "QuickCard Team",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "node start.js",
    "backend": "node bootstrap.js",
    "backend:watch": "nodemon --watch dist --ext js --delay 1 bootstrap.js",
    "prod": "node start.js --prod",
    "build": "nest build",
    "build:watch": "nest build --watch",
    "build:all": "nest build && npm run build --prefix frontend",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mongoose": "^10.0.2",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/throttler": "^5.1.1",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.0.1",
    "mongodb": "^7.2.0",
    "mongoose": "^8.1.1",
    "multer": "^1.4.5-lts.1",
    "nest-winston": "^1.9.4",
    "openai": "^4.26.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "puppeteer": "^21.11.0",
    "qrcode": "^1.5.3",
    "razorpay": "^2.9.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
    "concurrently": "^9.2.1",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
